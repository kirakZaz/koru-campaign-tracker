{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/api/$1" },
        { "source": "/((?!api/).*)", "destination": "/" }
    ],
    "crons": [
        {
            "path": "/api/cron/daily-reminder",
            "schedule": "0,30 4,5,6,7,8 * * 1-5"
        }
    ]
}
